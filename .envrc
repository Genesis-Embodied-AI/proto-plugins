dotenv_if_exists .env

# Auto-install the proto-pinned toolchain on entry and expose it on PATH.
# Requires proto (https://moonrepo.dev/proto) and direnv to be installed.
if ! has proto; then
  log_error "proto not found; install it: https://moonrepo.dev/docs/proto/install"
else
  proto use
  PATH_add "${PROTO_HOME:-$HOME/.proto}/shims"
  PATH_add "${PROTO_HOME:-$HOME/.proto}/bin"
fi
